# ---------- LLM (for RAG generation) ----------
LLM_API_KEY="填入你自己的key"
LLM_BASE_URL="http://macbook-pro-m1.local:8000/v1"
LLM_MODEL="Qwen3.6-35B-A3B-oQ4-fp16-mtp"
LLM_VERIFY_SSL=false

# ---------- Embedding (for vectorization) ----------
EMBEDDING_API_KEY="ollama"
EMBEDDING_BASE_URL="http://macbook-pro-m1.local:11434/v1"
EMBEDDING_MODEL="qwen3-embedding:0.6b"

# ---------- PostgreSQL (for pgvector backend) ----------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_db
DB_USER=postgres
DB_PASS=postgres
# Or use DATABASE_URL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_db

# ---------- Vector Store Backend ----------
# "auto"     -> pgvector if PostgreSQL config present, else chromadb
# "pgvector" -> force PostgreSQL + pgvector
# "chromadb" -> force local ChromaDB
# "qdrant"   -> force Qdrant
VECTOR_STORE=auto
CHROMA_PERSIST_DIR=data/chroma

# ---------- Qdrant ----------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_documents

# ---------- RAG Parameters ----------
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
